# Supabase — create a free project at https://supabase.com/dashboard,
# then copy these from Project Settings → API. Put real values in .env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — server-side only, never NEXT_PUBLIC. Used from M3 (AI insights).
ANTHROPIC_API_KEY=sk-ant-...
